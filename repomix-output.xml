  box-shadow: 0 6px 15px rgba(0,0,0,0.15);
}

.button-row button:disabled,
.footer-row button:disabled {
  background: #a0a0a0;
  cursor: not-allowed;
  opacity: 0.6;
  transform: none;
}

.button-row button:disabled:hover,
.footer-row button:disabled:hover {
  background: #a0a0a0;
  transform: none;
  box-shadow: none;
}

.output-section {
  margin-bottom: 20px;
}

